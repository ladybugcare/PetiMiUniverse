# Copiar para apps/hub-web/.env.local
# O Vite expõe variáveis com prefixo VITE_ ou REACT_APP_ (ver vite.config.ts).
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon
# Alternativa — mesmos nomes que no frontend/:
