import type { Request, Response } from 'express'
import { supabase } from '../config/supabase.ts'

interface VetBody {
  name: string
  crmv: string
  specialties: string[]
  certificates: string[]
  experience: string
  email: string
  password: string
}

export const createVet = async (req: Request<{}, {}, VetBody>, res: Response) => {
  const { name, crmv, specialties, certificates, experience, email, password } = req.body

  const { data, error } = await supabase
    .from('vets')
    .insert([{ name, crmv, specialties, certificates, experience, email, password }])
    .select()

  if (error) return res.status(400).json({ error })
  res.status(201).json({ vet: data[0] })
}

export const getVets = async (_req: Request, res: Response) => {
  const { data, error } = await supabase.from('vets').select('*')
  if (error) return res.status(400).json({ error })
  res.json({ vets: data })
}
