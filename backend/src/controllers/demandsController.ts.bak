import { Request, Response } from 'express'
import { supabase } from '../config/supabase.ts'

interface DemandBody {
  title: string
  description: string
  clinic_id: string
  status?: string
  payment?: number
}

export const createDemand = async (req: Request<{}, {}, DemandBody>, res: Response) => {
  const { title, description, clinic_id, status, payment } = req.body

  const { data, error } = await supabase
    .from('demands')
    .insert([{ title, description, clinic_id, status: status || 'open', payment }])
    .select()

  if (error) return res.status(400).json({ error })
  res.status(201).json({ demand: data[0] })
}

export const getDemands = async (_req: Request, res: Response) => {
  const { data, error } = await supabase.from('demands').select('*').eq('status', 'open')
  if (error) return res.status(400).json({ error })
  res.json({ demands: data })
}
