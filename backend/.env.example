# Copy to .env or .env.local (gitignored) and fill with your Supabase project values.
# Dashboard: https://app.supabase.com → Project → Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
# Legacy alias still supported:
# SUPABASE_KEY=your_anon_public_key

# Server-only — never expose in the frontend
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
HUB_WEB_URL=http://localhost:3002

# Produção (Railway): origens CORS, vírgula, sem barra final
# PRODUCTION_ORIGINS=https://petmi.app,https://hub.petmi.app,https://shift.petmi.app

# Opcional
# LOG_LEVEL=info

# Rate limit global (Railway/produção — opcional)
# GENERAL_RATE_LIMIT_MAX=800
# GENERAL_RATE_LIMIT_WINDOW_MS=900000
# HUB_RATE_LIMIT_MAX=2000

# Dev local (opcional — ver backend/.env.local)
# DISABLE_RATE_LIMIT=true
# HUB_DEV_ONLY=true
# DEBUG_CORS=true
