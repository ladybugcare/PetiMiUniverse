{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./", 
    "baseUrl": "./",
    "types": ["node"]
  },
  "ts-node": {
    "transpileOnly": true,
    "preferTsExts": true
  },
  "include": [
    "server.ts",
    "src/**/*",
    "routes/**/*",
    "controllers/**/*",
    "../frontend/hooks",
    "../frontend/context"
  ],
  "exclude": ["node_modules", "dist"]
}
