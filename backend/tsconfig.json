{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "./", 
    "baseUrl": "./",
    "types": ["node"],
    "noImplicitAny": false,
  },
  "ts-node": {
    "transpileOnly": true,
    "preferTsExts": true
  },
  "include": [
    "server.ts",
    "src/**/*",
    "routes/**/*",
    "controllers/**/*",
    "../frontend/hooks",
    "../frontend/context",
    "**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
