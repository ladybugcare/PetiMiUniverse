{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
     "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "types": ["node"],
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true
  },
  "ts-node": {
    "transpileOnly": true,
    "preferTsExts": true
  },
  "include": [
    "src/server.ts",
    "src/**/*",
    "routes/**/*",
    "controllers/**/*",
    "../frontend/hooks",
    "../frontend/context",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.integration.test.ts",
    "jest.config.ts"
  ]
}
