# Copy to .env.local in this folder (frontend/) and fill with your Supabase project.
# Dashboard: https://app.supabase.com → Project → Settings → API
# Restart `npm run web` after changing env files.

REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_public_key

REACT_APP_API_URL=http://localhost:3000

# Optional: same values for Expo / shared code paths
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
EXPO_PUBLIC_API_URL=http://localhost:3000
