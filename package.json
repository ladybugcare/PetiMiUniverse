{
  "name": "petivet",
  "version": "1.0.0",
  "description": "PetMi Vet - Plataforma de conexão entre clínicas veterinárias e veterinários",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "dev:vet-web": "cd frontend && npm run web",
    "dev:hub-web": "npm run dev --workspace=@petimi/hub-web",
    "dev:web": "cd frontend && npm run web",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build:web",
    "build:hub-web": "npm run build --workspace=@petimi/hub-web",
    "seed:clinic-e2e-demands": "node scripts/seed-clinic-e2e-demands.mjs",
    "seed:hub-beatriz-demo": "node scripts/seed-hub-beatriz-demo.mjs"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@testing-library/react": {
      "react": "18.2.0",
      "react-dom": "18.2.0",
      "@types/react-dom": "18.2.25"
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.61.0"
  }
}
