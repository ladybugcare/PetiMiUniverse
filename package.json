{
  "name": "petivet",
  "version": "1.0.0",
  "description": "PetiVet - Plataforma de conexão entre clínicas veterinárias e veterinários",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build:web"
  }
}
